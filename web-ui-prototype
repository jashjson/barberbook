  document.getElementById('sbSection').textContent = isB ? 'Barber Menu' : 'Customer Menu';
  document.getElementById('rswBarber').className = 'rsw-btn' + (isB ? ' active' : '');
  document.getElementById('rswCustomer').className = 'rsw-btn' + (!isB ? ' active' : '');
  document.querySelectorAll('.nav-btn[data-page]').forEach(btn => btn.onclick = () => goTo(btn.dataset.page));
}

function goTo(pageId) {
  ST.curPage = pageId;
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById(pageId).classList.add('active');
  const isB = pageId.startsWith('b');
  const navId = isB ? 'barberNav' : 'customerNav';
  const cls = isB ? 'active-green' : 'active-purple';
  document.querySelectorAll(`#${navId} .nav-btn`).forEach(b => b.classList.remove('active-green','active-purple'));
  const active = document.querySelector(`#${navId} [data-page="${pageId}"]`);
  if (active) active.classList.add(cls);
  renderPage();
}

function renderPage() {
  const map = { bHome:renderBarberHome, bAppts:renderAllAppts, bAvail:renderAvail, bEarn:renderEarnings, bProfile:renderBarberProfile, cHome:renderCustomerHome, cBookings:renderMyBookings, cNotifs:renderNotifs, cFavs:renderFavourites, cProfile:renderCustomerProfile };
