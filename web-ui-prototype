      <button class="btn btn-purple btn-sm" style="flex:1" onclick="snack('Reschedule feature coming soon!')">📅 Reschedule</button>
      <button class="btn btn-red-outline btn-sm" style="flex:1" onclick="confirm2('Cancel Booking','Cancel this appointment?','Yes, Cancel','var(--red)',()=>snack('Booking cancelled'))">✕ Cancel</button>
    </div>`:b.status==='completed'?`<div class="appt-actions"><button class="btn btn-outline btn-sm btn-full" onclick="snack('Review submitted ⭐')">⭐ Leave a Review</button></div>`:''}
  </div>`).join('') : '<div class="empty-state"><div class="empty-icon">📋</div><div>No bookings yet</div></div>'}`;
}

// ── NOTIFICATIONS ──
function renderNotifs() {
  const unread = NOTIFS.filter(n=>!n.read&&!ST.notifRead.includes(n.id)).length;
  document.getElementById('cNotifs').innerHTML = `
  <div class="page-header">
    <div><div class="page-title">Notifications</div><div class="page-subtitle">${unread} unread</div></div>
    ${unread?`<button class="btn btn-outline btn-sm" onclick="markAllRead()">Mark all read</button>`:''}
  </div>
  ${NOTIFS.map(n=>{
    const read = n.read || ST.notifRead.includes(n.id);
    return `<div class="notif-card ${read?'':'unread'}" onclick="ST.notifRead.push('${n.id}');renderNotifs()">
      <div class="notif-icon-box" style="background:${n.bg}">${n.icon}</div>
      <div style="flex:1">
        <div style="font-size:14px;font-weight:700">${n.title}</div>
        <div style="font-size:12px;color:var(--grey);margin-top:2px;line-height:1.5">${n.msg}</div>
        <div style="font-size:11px;color:var(--grey);margin-top:6px">${n.time}</div>
      </div>
      ${!read?'<div style="width:8px;height:8px;border-radius:50%;background:var(--green);margin-top:4px;flex-shrink:0"></div>':''}
    </div>`;
  }).join('')}`;
  updateNotifDot();
}

function markAllRead() {
  ST.notifRead = NOTIFS.map(n=>n.id);
  renderNotifs();
}

function updateNotifDot() {
  const count = NOTIFS.filter(n=>!n.read&&!ST.notifRead.includes(n.id)).length;
  const dot = document.getElementById('notifDot');
  if (!dot) return;
  dot.style.display = count ? 'flex' : 'none';
  dot.textContent = count;
}

// ── FAVOURITES ──
function renderFavourites() {
  const favs = BARBERS.filter(b=>ST.favs.includes(b.id));
  document.getElementById('cFavs').innerHTML = `
  <div class="page-header"><div class="page-title">Favourites</div><span class="sec-count">${favs.length} saved</span></div>
  ${favs.length ? favs.map(b=>barberCardHTML(b)).join('') : '<div class="empty-state"><div class="empty-icon">❤️</div><div>Heart a barber to save them here</div></div>'}`;
}

