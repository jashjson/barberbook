    <div class="field"><label>Full Name</label><input value="User"/></div>
    <div class="field"><label>Email</label><input type="email" placeholder="email@example.com"/></div>
    <div class="field"><label>Phone</label><input value="+91 98765 43210" readonly style="background:var(--bg);color:var(--grey)"/></div>
  </div>
  <div class="card" style="margin-bottom:16px">
    <div style="font-size:15px;font-weight:700;margin-bottom:14px">Notification Preferences</div>
    ${[['Booking confirmations',true],['Appointment reminders',true],['Promotional offers',false]].map(([lbl,def])=>`
