  <div class="card" style="margin-bottom:16px">
    <div style="display:flex;align-items:center;gap:16px;margin-bottom:16px">
      <div style="width:72px;height:72px;border-radius:50%;background:var(--purple-tint);color:var(--purple);display:flex;align-items:center;justify-content:center;font-size:28px;font-weight:800">U</div>
      <div>
        <div style="font-size:18px;font-weight:800">User</div>
        <div style="font-size:13px;color:var(--grey)">+91 98765 43210</div>
        <span class="badge badge-purple" style="margin-top:6px">⭐ Loyal Customer</span>
      </div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px;text-align:center;border-top:1px solid var(--border);padding-top:14px">
      ${[['Bookings',MY_BOOKINGS.length],['Favourites',ST.favs.length],['Completed',MY_BOOKINGS.filter(b=>b.status==='completed').length]].map(([l,v])=>`<div><div style="font-size:18px;font-weight:800;color:var(--purple)">${v}</div><div style="font-size:11px;color:var(--grey)">${l}</div></div>`).join('')}
    </div>
  </div>
  <div class="card" style="margin-bottom:16px">
