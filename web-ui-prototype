// ── CONFIRM DIALOG ──
function confirm2(title, msg, btnLabel, btnColor, cb) {
  document.getElementById('confirmTitle').textContent = title;
  document.getElementById('confirmMsg').textContent = msg;
  const btn = document.getElementById('confirmBtn');
  btn.textContent = btnLabel; btn.style.background = btnColor; btn.style.color = '#fff';
  btn.onclick = () => { closeOverlay('confirmOverlay'); cb(); };
  openOverlay('confirmOverlay');
}
</script>
</body>
