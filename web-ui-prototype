<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>BarberBook</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet"/>
<style>
:root{
  --green:#1D9E75;--green-dark:#18895e;--purple:#7F77DD;--purple-dark:#6b63cc;
  --bg:#F6F7F9;--white:#FFFFFF;--dark:#1A1A2E;--grey:#8A8A9A;--border:#E8E8F0;
  --red:#E24B4A;--amber:#EF9F27;
  --green-tint:rgba(29,158,117,.1);--purple-tint:rgba(127,119,221,.1);
  --red-tint:rgba(226,75,74,.1);--amber-tint:rgba(239,159,39,.1);
  --shadow-sm:0 1px 4px rgba(0,0,0,.06);--shadow-md:0 4px 16px rgba(0,0,0,.08);
  --r-sm:8px;--r-md:14px;--r-lg:20px;--r-xl:24px;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
body{font-family:'Plus Jakarta Sans',sans-serif;background:var(--bg);color:var(--dark);min-height:100vh;font-size:14px;overflow-x:hidden;}
button{font-family:inherit;cursor:pointer;}
input,textarea,select{font-family:inherit;}

/* ── SPLASH ── */
#splash{position:fixed;inset:0;background:var(--green);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:900;transition:opacity .5s ease;}
#splash.fade{opacity:0;pointer-events:none;}
.spl-logo{width:108px;height:108px;background:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:52px;box-shadow:0 12px 40px rgba(0,0,0,.18);margin-bottom:28px;animation:splashPop .9s cubic-bezier(.34,1.56,.64,1) both;}
.spl-name{font-size:38px;font-weight:800;color:#fff;letter-spacing:.4px;animation:slideUp .5s .3s both;}
.spl-sub{font-size:14px;color:rgba(255,255,255,.72);margin-top:8px;animation:slideUp .5s .45s both;}
.spl-dots{display:flex;gap:8px;margin-top:56px;animation:slideUp .4s .6s both;}
.spl-dot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.35);}
.spl-dot:first-child{background:#fff;}
@keyframes splashPop{from{transform:scale(.65);opacity:0}to{transform:scale(1);opacity:1}}
@keyframes slideUp{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}

/* ── ROLE SCREEN ── */
#roleScreen{position:fixed;inset:0;background:var(--white);z-index:800;display:none;flex-direction:column;padding:32px 24px;overflow-y:auto;}
#roleScreen.show{display:flex;}
.role-logo{display:flex;align-items:center;gap:10px;margin-bottom:48px;}
.role-logo-mark{width:40px;height:40px;background:var(--green-tint);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;}
.role-logo-text{font-size:20px;font-weight:800;color:var(--green);}
.role-heading{font-size:34px;font-weight:800;line-height:1.15;margin-bottom:8px;}
.role-sub{font-size:14px;color:var(--grey);margin-bottom:48px;}
.role-card{border:1.5px solid var(--border);border-radius:var(--r-xl);padding:22px;margin-bottom:18px;cursor:pointer;transition:border-color .2s,box-shadow .2s;background:var(--white);}
.role-card:hover{border-color:var(--green);box-shadow:0 8px 24px rgba(29,158,117,.12);}
.role-card.cust:hover{border-color:var(--purple);box-shadow:0 8px 24px rgba(127,119,221,.12);}
.role-card-top{display:flex;align-items:center;gap:16px;}
.role-card-icon{width:56px;height:56px;border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:26px;flex-shrink:0;}
.role-card-info{flex:1;}
.role-card-title{font-size:18px;font-weight:700;}
.role-card-desc{font-size:12px;color:var(--grey);line-height:1.5;margin-top:2px;}
.role-card-arrow{font-size:18px;color:var(--grey);}
.role-tags{display:flex;flex-wrap:wrap;gap:8px;margin-top:14px;padding-top:14px;border-top:1px solid var(--border);}
.role-tag{font-size:11.5px;font-weight:600;padding:5px 12px;border-radius:20px;}
.role-footer{display:flex;align-items:center;justify-content:center;gap:6px;margin-top:auto;padding-top:20px;font-size:12px;color:var(--grey);}

/* ── AUTH SCREEN ── */
#authScreen{position:fixed;inset:0;background:var(--white);z-index:800;display:none;flex-direction:column;}
#authScreen.show{display:flex;}
.auth-body{padding:28px 24px;flex:1;display:flex;flex-direction:column;overflow-y:auto;}
.auth-back{width:42px;height:42px;border:1px solid var(--border);border-radius:12px;background:none;display:flex;align-items:center;justify-content:center;font-size:18px;margin-bottom:30px;flex-shrink:0;}
.auth-icon-wrap{width:fit-content;padding:14px;border-radius:18px;margin-bottom:24px;font-size:30px;line-height:1;}
.auth-title{font-size:30px;font-weight:800;margin-bottom:8px;}
.auth-sub{font-size:14px;color:var(--grey);line-height:1.55;margin-bottom:36px;}
.phone-field{display:flex;align-items:center;border:1.5px solid var(--border);border-radius:var(--r-md);overflow:hidden;margin-bottom:12px;transition:border-color .2s;}
.phone-field:focus-within{border-color:var(--green);}
.phone-prefix{padding:14px;font-size:15px;font-weight:600;border-right:1px solid var(--border);white-space:nowrap;color:var(--dark);}
.phone-input{flex:1;padding:14px;font-size:18px;font-weight:600;border:none;outline:none;letter-spacing:2px;color:var(--dark);}
.otp-row{display:flex;gap:10px;margin-bottom:28px;justify-content:center;}
.otp-box{width:50px;height:58px;border:1.5px solid var(--border);border-radius:var(--r-md);text-align:center;font-size:24px;font-weight:700;outline:none;color:var(--dark);transition:border-color .2s;}
.otp-box:focus{border-color:var(--green);border-width:2px;}
.resend-row{text-align:center;font-size:13px;color:var(--grey);margin-top:16px;}
.resend-link{color:var(--green);font-weight:700;cursor:pointer;}
.terms{font-size:12px;color:var(--grey);text-align:center;margin-top:18px;line-height:1.6;}

/* ── MAIN APP ── */
#app{display:none;min-height:100vh;}
#app.show{display:flex;}
.sidebar{width:248px;background:var(--white);border-right:1px solid var(--border);position:fixed;top:0;left:0;height:100vh;z-index:100;display:flex;flex-direction:column;overflow-y:auto;}
.content{margin-left:248px;flex:1;min-height:100vh;}

.sb-header{padding:22px 18px 14px;display:flex;align-items:center;gap:10px;border-bottom:1px solid var(--border);}
.sb-logo-mark{width:36px;height:36px;background:var(--green-tint);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:17px;}
.sb-logo-text{font-size:17px;font-weight:800;color:var(--green);}
.role-switcher{display:flex;background:var(--bg);border-radius:10px;padding:3px;margin:10px 12px 4px;}
.rsw-btn{flex:1;padding:7px 6px;border:none;background:none;border-radius:8px;font-size:11.5px;font-weight:700;color:var(--grey);transition:.15s;}
.rsw-btn.active{background:var(--white);color:var(--green);box-shadow:var(--shadow-sm);}
.sb-section{font-size:10px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:var(--grey);padding:14px 18px 6px;}
.sb-nav{display:flex;flex-direction:column;gap:2px;padding:4px 10px;}
.nav-btn{display:flex;align-items:center;gap:10px;padding:10px 14px;border-radius:12px;border:none;background:none;width:100%;text-align:left;font-size:13.5px;font-weight:500;color:var(--grey);transition:.15s;position:relative;}
.nav-btn:hover{background:var(--bg);color:var(--dark);}
.nav-btn.active-green{background:var(--green-tint);color:var(--green);font-weight:700;}
.nav-btn.active-purple{background:var(--purple-tint);color:var(--purple);font-weight:700;}
.nav-icon{font-size:16px;width:20px;text-align:center;flex-shrink:0;}
.sb-footer{margin-top:auto;padding:10px 10px 14px;border-top:1px solid var(--border);}
.notif-dot{width:16px;height:16px;background:var(--red);color:#fff;border-radius:50%;font-size:9px;font-weight:700;display:flex;align-items:center;justify-content:center;margin-left:auto;}

/* ── PAGES ── */
.page{display:none;padding:24px 28px;max-width:900px;}
.page.active{display:block;}
.page-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:22px;gap:12px;}
.page-title{font-size:22px;font-weight:800;}
.page-subtitle{font-size:13px;color:var(--grey);margin-top:3px;}

/* ── CARDS ── */
.card{background:var(--white);border-radius:var(--r-lg);border:1px solid var(--border);padding:20px;}
.card-sm{background:var(--white);border-radius:var(--r-md);border:1px solid var(--border);padding:14px;}

/* ── STAT ROW ── */
.stat-row{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px;}
.stat-card{background:var(--white);border-radius:var(--r-md);border:1px solid var(--border);padding:14px;}
.stat-val{font-size:24px;font-weight:800;margin:6px 0 2px;}
.stat-lbl{font-size:11px;color:var(--grey);}

/* ── BADGE ── */
.badge{display:inline-flex;align-items:center;padding:4px 10px;border-radius:20px;font-size:11px;font-weight:700;}
.badge-green{background:var(--green-tint);color:var(--green);}
.badge-purple{background:var(--purple-tint);color:var(--purple);}
.badge-amber{background:var(--amber-tint);color:var(--amber);}
.badge-red{background:var(--red-tint);color:var(--red);}
.badge-grey{background:rgba(138,138,154,.1);color:var(--grey);}

/* ── BUTTONS ── */
.btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;padding:13px 22px;border-radius:var(--r-md);border:none;font-size:14px;font-weight:700;cursor:pointer;transition:.15s;font-family:inherit;}
.btn:disabled{opacity:.5;cursor:not-allowed;}
.btn-green{background:var(--green);color:#fff;}.btn-green:hover:not(:disabled){background:var(--green-dark);}
.btn-purple{background:var(--purple);color:#fff;}.btn-purple:hover:not(:disabled){background:var(--purple-dark);}
.btn-outline{background:transparent;border:1.5px solid var(--border);color:var(--dark);}.btn-outline:hover{border-color:var(--grey);}
.btn-red-outline{background:transparent;border:1.5px solid var(--red);color:var(--red);}
.btn-sm{padding:8px 14px;font-size:12px;border-radius:var(--r-sm);}
.btn-full{width:100%;}
.icon-btn{width:42px;height:42px;border-radius:12px;border:1px solid var(--border);background:var(--white);display:flex;align-items:center;justify-content:center;font-size:18px;}

/* ── SEARCH ── */
.search-wrap{position:relative;margin-bottom:14px;}
.search-icon{position:absolute;left:13px;top:50%;transform:translateY(-50%);color:var(--grey);font-size:16px;pointer-events:none;}
.search-input{width:100%;padding:13px 14px 13px 40px;border:1px solid var(--border);border-radius:var(--r-md);font-size:14px;background:var(--white);color:var(--dark);outline:none;transition:border-color .2s;}
.search-input:focus{border-color:var(--green);}

/* ── FILTER PILLS ── */
.filter-row{display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap;}
.filter-pill{padding:7px 16px;border-radius:20px;border:1px solid var(--border);background:var(--white);font-size:13px;font-weight:600;color:var(--grey);cursor:pointer;transition:.15s;}
.filter-pill.on{background:var(--purple);border-color:var(--purple);color:#fff;}
.filter-pill:hover:not(.on){background:var(--bg);}

/* ── PROMO BANNER ── */
.promo-banner{background:var(--purple);border-radius:var(--r-lg);padding:18px 20px;display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;}
.promo-claim{background:#fff;color:var(--purple);border:none;border-radius:20px;padding:8px 18px;font-size:13px;font-weight:700;cursor:pointer;}

/* ── BARBER CARD ── */
.barber-card{background:var(--white);border-radius:var(--r-lg);border:1px solid var(--border);padding:16px;display:flex;gap:14px;cursor:pointer;transition:.2s;margin-bottom:12px;}
.barber-card:hover{border-color:var(--purple);box-shadow:0 4px 20px rgba(127,119,221,.12);}
.barber-avatar{width:60px;height:60px;border-radius:50%;background:var(--purple-tint);color:var(--purple);font-size:22px;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0;position:relative;}
.online-indicator{position:absolute;bottom:1px;right:1px;width:14px;height:14px;border-radius:50%;border:2.5px solid var(--white);}
.barber-info{flex:1;min-width:0;}
.barber-name{font-size:15px;font-weight:700;}
.barber-shop{font-size:12px;color:var(--grey);}
.barber-meta{display:flex;align-items:center;gap:8px;margin-top:5px;font-size:12px;color:var(--grey);flex-wrap:wrap;}
.barber-footer{display:flex;align-items:center;justify-content:space-between;margin-top:8px;}
.barber-price{font-size:13px;font-weight:700;color:var(--purple);}
.fav-btn{background:none;border:none;font-size:18px;padding:2px;cursor:pointer;line-height:1;}

/* ── SECTION HEADER ── */
.sec-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
.sec-title{font-size:17px;font-weight:700;}
.sec-count{font-size:13px;color:var(--grey);}

/* ── STATUS BANNER ── */
.status-banner{border-radius:var(--r-lg);padding:16px 20px;display:flex;align-items:center;gap:12px;cursor:pointer;border:none;width:100%;text-align:left;margin-bottom:14px;transition:.2s;}
.status-dot-box{width:34px;height:34px;background:rgba(255,255,255,.22);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}

/* ── APPOINTMENT CARD ── */
.appt-card{background:var(--white);border-radius:var(--r-md);border:1px solid var(--border);padding:14px;margin-bottom:10px;}
.appt-row{display:flex;align-items:center;gap:10px;}
.appt-divider{width:1px;height:40px;background:var(--border);flex-shrink:0;}
.appt-avatar{width:36px;height:36px;border-radius:50%;background:var(--green-tint);color:var(--green);font-size:13px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.appt-info{flex:1;min-width:0;}
.appt-actions{display:flex;gap:8px;margin-top:10px;}

/* ── BOOKING STEPS ── */
.steps-row{display:flex;align-items:flex-start;margin-bottom:22px;}
.step-col{display:flex;flex-direction:column;align-items:center;flex:1;}
.step-line{flex:1;height:2px;margin-top:14px;}
.step-circle{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0;}
.step-name{font-size:10px;margin-top:4px;font-weight:600;text-align:center;}

/* ── SERVICE SELECT ── */
.service-row{border:1.5px solid var(--border);border-radius:var(--r-md);padding:16px;display:flex;align-items:center;gap:14px;cursor:pointer;transition:.2s;margin-bottom:10px;}
.service-row:hover,.service-row.sel{border-color:var(--purple);}
.service-row.sel{background:rgba(127,119,221,.04);}
.service-icon{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}

/* ── DATE PICKER ── */
.date-scroll{display:flex;gap:10px;overflow-x:auto;padding-bottom:4px;margin-bottom:16px;}
.date-chip{min-width:62px;height:84px;border-radius:var(--r-md);border:1px solid var(--border);background:var(--white);display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;transition:.2s;}
.date-chip:hover:not(.disabled):not(.active){border-color:var(--purple);}
.date-chip.active{background:var(--purple);border-color:var(--purple);}
.date-chip.disabled{opacity:.4;cursor:not-allowed;}

/* ── TIME GRID ── */
.time-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;}
.time-chip{padding:10px;border-radius:var(--r-sm);border:1px solid var(--border);background:var(--white);font-size:12px;font-weight:600;cursor:pointer;text-align:center;transition:.2s;}
.time-chip:hover:not(.booked):not(.active){border-color:var(--purple);}
.time-chip.active{background:var(--purple);border-color:var(--purple);color:#fff;}
.time-chip.booked{background:var(--bg);color:rgba(138,138,154,.45);cursor:not-allowed;}

/* ── CONFIRM ROWS ── */
.conf-row{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid var(--border);}
.conf-row:last-child{border-bottom:none;}
.conf-key{font-size:13px;color:var(--grey);flex:1;}
.conf-val{font-size:14px;font-weight:700;}

/* ── TABS ── */
.tab-bar{display:flex;background:var(--white);border-radius:12px;padding:4px;border:1px solid var(--border);margin-bottom:16px;}
.tab-btn{flex:1;padding:9px 4px;border-radius:9px;border:none;background:none;font-size:12.5px;font-weight:700;color:var(--grey);cursor:pointer;transition:.15s;text-align:center;}
.tab-btn.active{background:var(--bg);color:var(--dark);box-shadow:var(--shadow-sm);}

/* ── EARNINGS ── */
.earnings-card{background:var(--green);border-radius:var(--r-xl);padding:24px;color:#fff;margin-bottom:14px;}
.earnings-total{font-size:42px;font-weight:800;margin:6px 0 18px;}
.bar-chart{display:flex;align-items:flex-end;justify-content:space-between;height:110px;margin-top:14px;padding:0 4px;}
.bar-col{display:flex;flex-direction:column;align-items:center;gap:4px;flex:1;}
.bar-fill{width:24px;border-radius:6px;background:rgba(255,255,255,.72);}
.bar-lbl{font-size:10px;color:rgba(255,255,255,.6);}
.bar-amt{font-size:9px;color:rgba(255,255,255,.8);}

/* ── NOTIFICATIONS ── */
.notif-card{background:var(--white);border-radius:var(--r-md);border:1px solid var(--border);padding:14px;display:flex;gap:12px;cursor:pointer;margin-bottom:10px;transition:.15s;}
.notif-card.unread{border-left:3.5px solid var(--green);}
.notif-card:hover{background:var(--bg);}
.notif-icon-box{width:42px;height:42px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}

/* ── AVAILABILITY ── */
.avail-row{background:var(--white);border-radius:var(--r-md);border:1px solid var(--border);padding:14px;display:flex;align-items:center;gap:12px;margin-bottom:10px;}
.avail-day{font-size:14px;font-weight:700;width:90px;flex-shrink:0;}
.avail-time{font-size:13px;color:var(--grey);flex:1;}
.toggle{position:relative;width:48px;height:26px;flex-shrink:0;}
.toggle input{opacity:0;width:0;height:0;position:absolute;}
.toggle-track{position:absolute;inset:0;background:var(--border);border-radius:13px;cursor:pointer;transition:.3s;}
.toggle-track:before{content:'';position:absolute;width:20px;height:20px;background:#fff;border-radius:50%;left:3px;top:3px;transition:.3s;box-shadow:0 1px 4px rgba(0,0,0,.18);}
.toggle input:checked+.toggle-track{background:var(--green);}
.toggle input:checked+.toggle-track:before{transform:translateX(22px);}

/* ── EDIT FIELDS ── */
.field{display:flex;flex-direction:column;gap:4px;margin-bottom:14px;}
.field label{font-size:12px;font-weight:700;color:var(--grey);}
.field input,.field textarea,.field select{padding:12px 14px;border:1.5px solid var(--border);border-radius:12px;font-size:14px;color:var(--dark);outline:none;resize:vertical;transition:border-color .2s;}
.field input:focus,.field textarea:focus,.field select:focus{border-color:var(--green);}

/* ── OVERLAYS ── */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:600;display:none;align-items:flex-end;justify-content:center;}
.overlay.show{display:flex;}
.sheet{background:var(--white);border-radius:var(--r-xl) var(--r-xl) 0 0;width:100%;max-width:560px;padding:24px 24px 36px;animation:sheetUp .25s ease;}
@keyframes sheetUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
.sheet-title{font-size:18px;font-weight:800;margin-bottom:16px;}

.dialog-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:700;display:none;align-items:center;justify-content:center;}
.dialog-overlay.show{display:flex;}
.dialog{background:var(--white);border-radius:var(--r-xl);padding:26px;max-width:380px;width:90%;animation:dialogPop .25s ease;}
@keyframes dialogPop{from{transform:scale(.88);opacity:0}to{transform:scale(1);opacity:1}}

.success-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:700;display:none;align-items:center;justify-content:center;}
.success-overlay.show{display:flex;}
.success-box{background:var(--white);border-radius:var(--r-xl);padding:32px 28px;max-width:340px;width:90%;text-align:center;animation:dialogPop .3s ease;}
.success-icon{width:84px;height:84px;background:var(--green-tint);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:42px;margin:0 auto 18px;}

/* ── SNACKBAR ── */
.snack{position:fixed;bottom:100px;left:50%;transform:translateX(-50%) translateY(60px);background:var(--dark);color:#fff;padding:12px 24px;border-radius:12px;font-size:13px;font-weight:600;z-index:999;opacity:0;transition:.28s;pointer-events:none;white-space:nowrap;}
