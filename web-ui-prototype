  setTimeout(() => {
    document.getElementById('splash').classList.add('fade');
    setTimeout(showRole, 500);
  }, 1800);
});

function showRole() {
  document.getElementById('authScreen').classList.remove('show');
  document.getElementById('roleScreen').classList.add('show');
}

function chooseRole(r) {
  ST.role = r;
  const isB = r === 'barber';
  const color = isB ? 'var(--green)' : 'var(--purple)';
  document.getElementById('authIconWrap').textContent = isB ? '✂️' : '👤';
  document.getElementById('authIconWrap').style.background = isB ? 'var(--green-tint)' : 'var(--purple-tint)';
