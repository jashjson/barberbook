<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.BarberBook" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_variant</item>
        <item name="colorOnPrimaryContainer">@color/on_primary</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/on_accent</item>
        <item name="colorSecondaryContainer">@color/accent</item>
        <item name="colorOnSecondaryContainer">@color/on_accent</item>

        <!-- Tertiary brand color. -->
        <item name="colorTertiary">@color/gray_600</item>
        <item name="colorOnTertiary">@color/white</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/primary</item>
        
        <!-- Background and Surface -->
        <item name="android:windowBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
    </style>
    
    <!-- Custom button style -->
    <style name="Widget.BarberBook.Button" parent="Widget.Material3.Button">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.BarberBook.Button</item>
    </style>
    
    <style name="ShapeAppearance.BarberBook.Button" parent="">
        <item name="cornerSize">12dp</item>
    </style>
    
    <!-- Custom card style -->
    <style name="Widget.BarberBook.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.BarberBook.Card</item>
    </style>
    
    <style name="ShapeAppearance.BarberBook.Card" parent="">
        <item name="cornerSize">16dp</item>
    </style>
</resources>